<div class="timeline">
  <slot />
</div>

<style>
  .timeline {
    position: relative;
    padding: 2rem 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 1.5rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-primary-blue);
  }

  @media (max-width: 768px) {
    .timeline::before {
      left: 0.75rem;
    }
  }
</style>
