---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<div class="justification">
  {title && <strong>{title}</strong>}
  <slot />
</div>

<style>
  .justification {
    background: #fafafa;
    border-left: 4px solid var(--color-primary-blue);
    padding: 1rem 1.5rem;
    border-radius: var(--border-radius-base);
    margin: 1.5rem 0;
  }

  .justification strong {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--color-primary-blue);
    font-size: 0.95rem;
  }

  .justification :global(p) {
    margin: 0.5rem 0;
    color: #555;
  }

  .justification :global(p:first-of-type) {
    margin-top: 0;
  }

  .justification :global(p:last-of-type) {
    margin-bottom: 0;
  }
</style>
