---
interface Props {
  phase?: number;
  title: string;
  period?: string;
  goal?: string;
}
const { phase = 1, title, period, goal } = Astro.props;
---

<div class={`timeline-item phase-${phase}`}>
  {period && <div class="timeline-period">{period}</div>}
  <div class="timeline-title">{title}</div>
  <slot />
  {goal && <div class="timeline-goal">{goal}</div>}
</div>

<style>
  .timeline-item {
    position: relative;
    padding-left: 4rem;
    margin-bottom: 2rem;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: 0.65rem;
    top: 0;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 50%;
    background: white;
    border: 3px solid var(--color-primary-blue);
  }

  .timeline-period {
    font-size: 0.85rem;
    color: #999;
    margin-bottom: 0.25rem;
  }

  .timeline-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary-blue);
    margin-bottom: 0.5rem;
  }

  .timeline-goal {
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    background: #f0f7ff;
    border-left: 3px solid var(--color-accent-blue);
    border-radius: 4px;
    font-size: 0.9rem;
    color: #004d73;
  }

  /* Phase colors */
  .phase-1::before {
    border-color: #1976d2;
    background: #e3f2fd;
  }

  .phase-2::before {
    border-color: #0096d2;
    background: #e0f7fa;
  }

  .phase-3::before {
    border-color: #388e3c;
    background: #e8f5e9;
  }

  .phase-4::before {
    border-color: #f57c00;
    background: #fff3e0;
  }

  @media (max-width: 768px) {
    .timeline-item {
      padding-left: 3rem;
    }

    .timeline-item::before {
      left: 0.4rem;
      width: 1.2rem;
      height: 1.2rem;
    }
  }
</style>
