---
/**
 * Icon component using inline Lucide-style SVGs.
 * All icons follow stroke-based design with consistent 24x24 viewBox.
 * Colors are controlled via CSS `currentColor`, inheriting from parent.
 *
 * @prop {string} name - Icon name (see ICONS map below)
 * @prop {number} size - Icon size in pixels (default: 24)
 * @prop {string} className - Optional CSS class
 * @prop {string} strokeWidth - SVG stroke width (default: "2")
 * @prop {string} label - Optional accessible label (adds aria-label)
 */
interface Props {
  name: string;
  size?: number;
  className?: string;
  strokeWidth?: string;
  label?: string;
}

const { name, size = 24, className = '', strokeWidth = '2', label } = Astro.props;

