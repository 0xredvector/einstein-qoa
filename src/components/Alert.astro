---
interface Props {
  variant?: 'critical' | 'warning' | 'info' | 'success';
  title?: string;
  icon?: string;
}
const { variant = 'info', title, icon } = Astro.props;
const defaultIcons: Record<string, string> = { critical: '⚠', warning: '⚠', info: 'ℹ', success: '✓' };
const displayIcon = icon || defaultIcons[variant] || 'ℹ';
---

<div class={`alert alert-${variant}`}>
  <span class="alert-icon">{displayIcon}</span>
  <div>
    {title && <strong>{title}</strong>}
    <slot />
  </div>
</div>

<style>
  .alert {
    display: flex;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-radius: var(--border-radius-base);
    border-left: 4px solid;
    margin: 1.5rem 0;
  }

  .alert-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .alert strong {
    display: block;
    margin-bottom: 0.25rem;
  }

  /* Variants */
  .alert-info {
    background: rgba(25, 118, 210, 0.08);
    border-color: #1976d2;
    color: #0d47a1;
  }

  .alert-info .alert-icon {
    color: #1976d2;
  }

  .alert-success {
    background: rgba(56, 142, 60, 0.08);
    border-color: #388e3c;
    color: #1b5e20;
  }

  .alert-success .alert-icon {
    color: #388e3c;
  }

  .alert-warning {
    background: rgba(245, 124, 0, 0.08);
    border-color: #f57c00;
    color: #e65100;
  }

  .alert-warning .alert-icon {
    color: #f57c00;
  }

  .alert-critical {
    background: rgba(211, 47, 47, 0.08);
    border-color: #d32f2f;
    color: #b71c1c;
  }

  .alert-critical .alert-icon {
    color: #d32f2f;
  }
</style>
